# 环境变量配置文件模板
# 复制此文件为 .env 并填入实际的 API 密钥

# LLM API 配置
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_ID=qwen3.5-flash
LLM_RULES_MODEL_ID=qwen3.5-flash
LLM_BATCH_MODEL_ID=qwen3.5-flash
LLM_SUMMARY_MODEL_ID=qwen3.5-flash
LLM_DAILY_SUMMARY_MODEL_ID=qwen3.5-flash
LLM_MODEL_OPTIONS=qwen3.5-flash
LLM_TIMEOUT=60
LLM_RULES_TIMEOUT=120
LLM_BATCH_TIMEOUT=120
LLM_SUMMARY_TIMEOUT=60
LLM_DAILY_SUMMARY_TIMEOUT=120
LLM_DAILY_SUMMARY_STOCK_TIMEOUT=180

# Tavily API 配置 (用于新闻搜索)
TAVILY_API_KEY=your_tavily_api_key_here

# Finnhub API 配置 (用于英文财经新闻采集)
FINNHUB_API_KEY=your_finnhub_api_key_here

# 日志级别
LOG_LEVEL=INFO

# 存储与写入模式
DB_BACKEND=local
ENABLE_REMOTE_WRITE=false
USE_DEMO_DATA=false

# Cloudflare / Workers API 配置
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
D1_DATABASE_ID=your_d1_database_id
INGEST_API_BASE_URL=https://your-worker.your-subdomain.workers.dev
INGEST_API_TOKEN=replace_with_secure_random_token
# 可选：前端写操作单独令牌；未配置时 Worker 会回退复用 INGEST_API_TOKEN
APP_API_TOKEN=replace_with_optional_ui_write_token
